{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "STM32 Dynamic Debug",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/${input:get_current_build}/zephyr/zephyr.elf",
            "request": "launch",
            "type": "cortex-debug",
            "servertype": "openocd",
            "serverpath": "${workspaceFolder}/zephyr-sdk/sysroots/x86_64-pokysdk-linux/usr/bin/openocd",
            "gdbPath": "${workspaceFolder}/zephyr-sdk/arm-zephyr-eabi/bin/arm-zephyr-eabi-gdb",
            "armToolchainPath": "${workspaceFolder}/zephyr-sdk/arm-zephyr-eabi/bin",
            "toolchainPrefix": "arm-zephyr-eabi",
            "device": "STM32F407VE",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32f4x.cfg"
            ],
            "interface": "swd",
            "showDevDebugOutput": "raw",
            "runToEntryPoint": "main"
        }
    ],
    "inputs": [
        {
            "id": "get_current_build",
            "type": "command",
            "command": "extension.commandvariable.file.content",
            "args": {
                "fileName": "${workspaceFolder}/.current"
            }
        }
    ]
}