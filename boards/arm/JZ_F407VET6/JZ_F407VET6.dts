/dts-v1/;
#include <st/f4/stm32f407Xe.dtsi>
#include <st/f4/stm32f407v(e-g)tx-pinctrl.dtsi>
#include <zephyr/dt-bindings/input/input-event-codes.h>

/ {
	model = "JZ-F407VET6 development board";
	compatible = "st,stm32f407";

	chosen {
		zephyr,console = &usart6;
		zephyr,shell-uart = &usart6;
		zephyr,uart-mcumgr = &usart3;
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,ccm = &ccm0;
		zephyr,canbus = &can1;
		zephyr,entropy = &rng;
	};

	aliases {
		led0 = &led_1;
		led1 = &led_2;
		led2 = &led_3;
		sw0 = &button_1;
		sw1 = &button_2;
		sw2 = &button_3;
		spi-flash0 = &w25q64;
		watchdog0 = &iwdg;
		eeprom-0 = &eeprom;
	};

	leds: leds {
		compatible = "gpio-leds";

		led_1: led1 {
			gpios = <&gpioe 13 GPIO_ACTIVE_LOW>;
			label = "LED 1";
		};

		led_2: led2 {
			gpios = <&gpioe 14 GPIO_ACTIVE_LOW>;
			label = "LED 2";
		};

		led_3: led3 {
			gpios = <&gpioe 15 GPIO_ACTIVE_LOW>;
			label = "LED 3";
		};
	};

	gpio_keys {
		compatible = "gpio-keys";
		button_1: button1 {
			label = "SW 1";
			gpios = <&gpioe 12 GPIO_ACTIVE_LOW>;
			zephyr,code = <INPUT_KEY_0>;
		};

		button_2: button2 {
			label = "SW 2";
			gpios = <&gpioe 11 GPIO_ACTIVE_LOW>;
			zephyr,code = <INPUT_KEY_1>;
		};

		button_3: button3 {
			label = "SW 3";
			gpios = <&gpioe 10 GPIO_ACTIVE_LOW>;
			zephyr,code = <INPUT_KEY_2>;
		};
	};

	fstab {
		compatible = "zephyr,fstab";
		lfs1: lfs1 {
			compatible = "zephyr,fstab,littlefs";
			mount-point = "/lfs:";
			partition = <&storage_partition>;
			automount;
			read-size = <256>;
			prog-size = <256>;
			cache-size = <256>;
			lookahead-size = <256>;
			block-cycles = <512>;
		};
	};
};

&flash0 {
	reg = <0x08000000 DT_SIZE_K(512)>;
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		boot_partition: partition@0 {
			label = "mcuboot";
			reg = <0x00000000 DT_SIZE_K(512)>;
		};
	};
};

&sram0 {
	status = "okay";
	reg = <0x20000000 DT_SIZE_K(128)>;
};

&clk_hse {
	clock-frequency = <DT_FREQ_M(25)>;
	status = "okay";
};

&pll {
	div-m = <25>;
	mul-n = <336>;
	div-p = <2>;
	div-q = <7>;
	clocks = <&clk_hse>;
	status = "okay";
};

&rcc {
	clocks = <&pll>;
	clock-frequency = <DT_FREQ_M(168)>;
	ahb-prescaler = <1>;
	apb1-prescaler = <4>;
	apb2-prescaler = <2>;
};

&usart1 {
	pinctrl-0 = <&usart1_tx_pa9 &usart1_rx_pa10>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

&usart2 {
	pinctrl-0 = <&usart2_tx_pd5 &usart2_rx_pd6>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

&usart3 {
	pinctrl-0 = <&usart3_tx_pd8 &usart3_rx_pd9>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

&usart6 {
	pinctrl-0 = <&usart6_tx_pc6 &usart6_rx_pc7>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

&can1 {
	pinctrl-0 = <&can1_rx_pd0 &can1_tx_pd1>;
	pinctrl-names = "default";
	status = "okay";
};

&i2c1 {
    pinctrl-0 = <&i2c1_scl_pb8 &i2c1_sda_pb9>;
    pinctrl-names = "default";
    status = "okay";
    clock-frequency = <I2C_BITRATE_STANDARD>;

    eeprom: at24c02@50 {
        compatible = "atmel,at24";
        reg = <0x50>;
        size = <256>;
        pagesize = <8>;
        address-width = <8>;
        timeout = <5>;
    };
};

&can2 {
	pinctrl-0 = <&can2_rx_pb5 &can2_tx_pb6>;
	pinctrl-names = "default";
	status = "okay";
};

&spi2 {
	pinctrl-0 = <&spi2_sck_pb10 &spi2_miso_pc2 &spi2_mosi_pc3>;
	pinctrl-names = "default";
	cs-gpios = <&gpioe 3 GPIO_ACTIVE_LOW>;
	status = "okay";

	w25q64: w25q64jv@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <80000000>;
		jedec-id = [ef 40 17];
		size = <0x4000000>;
		has-dpd;
		t-enter-dpd = <3500>;
		t-exit-dpd = <3500>;
		status = "okay";

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;
			storage_partition: partition@0 {
				label = "storage";
				reg = <0x00000000 DT_SIZE_M(8)>;
			};
		};
	};
};

&sdmmc1 {
	status = "okay";
	disk-name = "SD";
	pinctrl-0 = <&sdio_d0_pc8 
				  &sdio_d1_pc9 
				  &sdio_d2_pc10 
				  &sdio_d3_pc11
				  &sdio_ck_pc12 
				  &sdio_cmd_pd2>;
	pinctrl-names = "default";
	cd-gpios = <&gpiod 3 GPIO_ACTIVE_LOW>;
	bus-width = <4>;
};

&rtc {
	clocks = <&rcc STM32_CLOCK_BUS_APB1 0x10000000>,
		 <&rcc STM32_SRC_LSE RTC_SEL(1)>;
	status = "okay";
};

zephyr_udc0: &usbotg_fs {
	pinctrl-0 = <&usb_otg_fs_dm_pa11 &usb_otg_fs_dp_pa12>;
	pinctrl-names = "default";
	status = "okay";
	cdc_acm_uart0: cdc-acm-uart0 {
		compatible = "zephyr,cdc-acm-uart";
	};
};

&mac {
	status = "okay";
	pinctrl-0 = <&eth_rxd0_pc4 
			 &eth_rxd1_pc5
		         &eth_ref_clk_pa1 
			 &eth_crs_dv_pa7
		         &eth_tx_en_pb11 
			 &eth_txd0_pb12 
			 &eth_txd1_pb13>;
	pinctrl-names = "default";
	phy-connection-type = "rmii";
	phy-handle = <&eth_phy>;

};

&mdio {
	status = "okay";
	pinctrl-0 = <&eth_mdio_pa2 &eth_mdc_pc1>;
	pinctrl-names = "default";

	eth_phy: ethernet-phy@1 {
		compatible = "ethernet-phy";
		reg = <1>;
	};
};

&iwdg {
	status = "okay";
};

&backup_sram {
	status = "okay";
};

&rng {
    status = "okay";
};